All from AI Governance, Ethics & Leadership. The premier destination for AI Governance & Responsible AI.","image":[{"@type":"ImageObject","url":"https://substack-post-media.s3.amazonaws.com/public/images/af745517-2009-4274-bb67-aa080d46140e_1920x1080.png"}],"datePublished":"2026-06-01T21:08:39+00:00","dateModified":"2026-06-01T21:08:39+00:00","isAccessibleForFree":false,"author":[{"@type":"Person","name":"AI Governance Lead \u26A1","url":"https://substack.com/@aigovernancelead","description":"Stanford certified engineering leader and MBA turned AI Governance Leader. Coffee lover, plant parent and AI enthusiast.","identifier":"user:329493704","image":{"@type":"ImageObject","contentUrl":"https://substackcdn.com/image/fetch/$s_!oN3h!,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F367e26c8-29b1-418c-92ac-395f33cce4e0_589x589.png","thumbnailUrl":"https://substackcdn.com/image/fetch/$s_!oN3h!,w_128,h_128,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F367e26c8-29b1-418c-92ac-395f33cce4e0_589x589.png"}}],"publisher":{"@type":"Organization","name":"AI Governance, Ethics and Leadership","url":"https://aigovernancelead.substack.com","description":"I make AI governance clear, practical, and human for 7500+ people who want to lead with confidence.","identifier":"pub:4560681","logo":{"@type":"ImageObject","url":"https://substackcdn.com/image/fetch/$s_!S4Jb!,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F47869115-def2-4229-92a8-6e6aeabb12e6_896x896.png","contentUrl":"https://substackcdn.com/image/fetch/$s_!S4Jb!,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F47869115-def2-4229-92a8-6e6aeabb12e6_896x896.png","thumbnailUrl":"https://substackcdn.com/image/fetch/$s_!S4Jb!,w_128,h_128,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F47869115-def2-4229-92a8-6e6aeabb12e6_896x896.png"},"image":{"@type":"ImageObject","url":"https://substackcdn.com/image/fetch/$s_!S4Jb!,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F47869115-def2-4229-92a8-6e6aeabb12e6_896x896.png","contentUrl":"https://substackcdn.com/image/fetch/$s_!S4Jb!,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F47869115-def2-4229-92a8-6e6aeabb12e6_896x896.png","thumbnailUrl":"https://substackcdn.com/image/fetch/$s_!S4Jb!,w_128,h_128,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F47869115-def2-4229-92a8-6e6aeabb12e6_896x896.png"}},"interactionStatistic":[{"@type":"InteractionCounter","interactionType":"https://schema.org/LikeAction","userInteractionCount":58},{"@type":"InteractionCounter","interactionType":"https://schema.org/ShareAction","userInteractionCount":8},{"@type":"InteractionCounter","interactionType":"https://schema.org/CommentAction","userInteractionCount":0}]}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"AI Governance, Ethics and Leadership","item":"https://aigovernancelead.substack.com"},{"@type":"ListItem","position":2,"name":"AI Governance In Action: Harvey LAB Benchmark Puts Claude, Gemini, and ChatGPT to the Test","item":"https://aigovernancelead.substack.com/p/harvey-lab-legal-ai-benchmark-responsible-ai"}]}</script><div aria-label="Post" role="main" class="single-post-container"><div class="container"><div class="single-post"><div class="pencraft pc-display-contents pc-reset pubTheme-yiXxQA"><article class="typography newsletter-post post"><div role="region" aria-label="Post header" class="post-header"><h1 dir="auto" class="post-title published title-X77sOw">AI Governance In Action: Harvey LAB Benchmark Puts Claude, Gemini, and ChatGPT to the Test</h1><h3 dir="auto" class="subtitle subtitle-HEEcLo">A brutal, auditable stress test that turns model claims into governance evidence for firms, courts, and regulators.</h3><div aria-label="Post UFI" role="region" class="pencraft pc-display-flex pc-flexDirection-column pc-paddingBottom-16 pc-reset"><div class="pencraft pc-display-flex pc-paddingTop-16 pc-paddingBottom-16 pc-justifyContent-space-between pc-alignItems-center pc-reset"><div class="pencraft pc-display-flex pc-gap-12 pc-alignItems-center pc-reset byline-wrapper"><div class="pencraft pc-display-flex pc-reset"><div class="pencraft pc-display-flex pc-flexDirection-row pc-gap-8 pc-alignItems-center pc-justifyContent-flex-start pc-reset"><div style="--scale:36px;--offset:9px;--border-width:4.5px;" class="pencraft pc-display-flex pc-flexDirection-row pc-alignItems-center pc-justifyContent-flex-start pc-reset ltr-qDBmby"><a href="https://substack.com/@aigovernancelead" aria-label="View AI Governance Lead ⚡'s profile" class="pencraft pc-display-contents pc-reset"><div style="--scale:36px;" tabindex="0" class="pencraft pc-display-flex pc-width-36 pc-height-36 pc-justifyContent-center pc-alignItems-center pc-position-relative pc-reset bg-secondary-UUD3_J flex-auto-j3S2WA animate-XFJxE4 outline-detail-vcQLyr pc-borderRadius-full overflow-hidden-WdpwT6 sizing-border-box-DggLA4 pressable-sm-YIJFKJ showFocus-sk_vEm container-TAtrWj interactive-UkK0V6 avatar-u8q6xB last-JfNEJ_"><div style="--scale:36px;" title="AI Governance Lead ⚡" class="pencraft pc-display-flex pc-width-36 pc-height-36 pc-justifyContent-center pc-alignItems-center pc-position-relative pc-reset bg-secondary-UUD3_J flex-auto-j3S2WA outline-detail-vcQLyr pc-borderRadius-full overflow-hidden-WdpwT6 sizing-border-box-DggLA4 container-TAtrWj"><picture><source type="image/webp" srcset="https://substackcdn.com/image/fetch/$s_!oN3h!,w_36,h_36,c_fill,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F367e26c8-29b1-418c-92ac-395f33cce4e0_589x589.png 1x, https://substackcdn.com/image/fetch/$s_!oN3h!,w_72,h_72,c_fill,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F367e26c8-29b1-418c-92ac-395f33cce4e0_589x589.png 2x, https://substackcdn.com/image/fetch/$s_!oN3h!,w_108,h_108,c_fill,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F367e26c8-29b1-418c-92ac-395f33cce4e0_589x589.png 3x"/><img src="https://substackcdn.com/image/fetch/$s_!oN3h!,w_36,h_36,c_fill,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F367e26c8-29b1-418c-92ac-395f33cce4e0_589x589.png" alt="AI Governance Lead ⚡'s avatar" srcset="https://substackcdn.com/image/fetch/$s_!oN3h!,w_36,h_36,c_fill,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F367e26c8-29b1-418c-92ac-395f33cce4e0_589x589.png 1x, https://substackcdn.com/image/fetch/$s_!oN3h!,w_72,h_72,c_fill,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F367e26c8-29b1-418c-92ac-395f33cce4e0_589x589.png 2x, https://substackcdn.com/image/fetch/$s_!oN3h!,w_108,h_108,c_fill,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2F367e26c8-29b1-418c-92ac-395f33cce4e0_589x589.png 3x" width="36" height="36" draggable="false" class="img-OACg1c object-fit-cover-u4ReeV pencraft pc-reset"/></picture></div></div></a></div></div></div><div class="pencraft pc-display-flex pc-flexDirection-column pc-reset"><div class="pencraft pc-reset color-pub-primary-text-NyXPlw line-height-20-t4M0El font-meta-MWBumP size-11-NuY2Zx weight-medium-fw81nC transform-uppercase-yKDgcq reset-IxiVJZ meta-EgzBVA"><span style="min-width:0;" data-state="closed"><a href="https://substack.com/@aigovernancelead" class="pencraft pc-reset decoration-hover-underline-ClDVRM reset-IxiVJZ">AI Governance Lead ⚡</a></span></div><div class="pencraft pc-display-flex pc-gap-4 pc-reset"><div class="pencraft pc-reset color-pub-secondary-text-hGQ02T line-height-20-t4M0El font-meta-MWBumP size-11-NuY2Zx weight-medium-fw81nC transform-uppercase-yKDgcq reset-IxiVJZ meta-EgzBVA">Jun 01, 2026</div><div class="pencraft pc-reset color-pub-secondary-text-hGQ02T line-height-20-t4M0El font-meta-MWBumP size-11-NuY2Zx weight-medium-fw81nC transform-uppercase-yKDgcq reset-IxiVJZ meta-EgzBVA">∙ Paid</div></div></div></div></div><div class="pencraft pc-display-flex pc-gap-16 pc-justifyContent-space-between pc-alignItems-center pc-reset flex-grow-rzmknG post-ufi"><div class="pencraft pc-display-flex pc-gap-8 pc-reset"><div class="like-button-container post-ufi-button style-button"><button tabindex="0" type="button" aria-label="Like (58)" aria-pressed="false" class="pencraft pc-reset pencraft post-ufi-button style-button has-label with-border"><svg role="img" style="height:20px;width:20px;" width="20" height="20" viewBox="0 0 24 24" fill="#000000" stroke-width="2" stroke="#000" xmlns="http://www.w3.org/2000/svg" class="icon"><g><title></title><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path></svg></g></svg><div class="label">58</div></button></div><button tabindex="0" type="button" aria-label="View comments (0)" data-href="https://aigovernancelead.substack.com/p/harvey-lab-legal-ai-benchmark-responsible-ai/comments" class="pencraft pc-reset pencraft post-ufi-button style-button post-ufi-comment-button no-label with-border"><svg role="img" style="height:20px;width:20px;" width="20" height="20" viewBox="0 0 24 24" fill="#000000" stroke-width="2" stroke="#000" xmlns="http://www.w3.org/2000/svg" class="icon"><g><title></title><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-circle"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg></g></svg></button><button tabindex="0" type="button" id="radix-P0-27" aria-haspopup="menu" aria-expanded="false" data-state="closed" class="pencraft pc-reset pencraft post-ufi-button style-button has-label with-border"><svg role="img" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke-width="2" stroke="var(--color-fg-primary)" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" class="icon"><g><title></title><path d="M2.53001 7.81595C3.49179 4.73911 6.43281 2.5 9.91173 2.5C13.1684 2.5 15.9537 4.46214 17.0852 7.23684L17.6179 8.67647M17.6179 8.67647L18.5002 4.26471M17.6179 8.67647L13.6473 6.91176M17.4995 12.1841C16.5378 15.2609 13.5967 17.5 10.1178 17.5C6.86118 17.5 4.07589 15.5379 2.94432 12.7632L2.41165 11.3235M2.41165 11.3235L1.5293 15.7353M2.41165 11.3235L6.38224 13.0882"></path></g></svg><div class="label">8</div></button></div><div class="pencraft pc-display-flex pc-gap-8 pc-reset"><button tabindex="0" type="button" class="pencraft pc-reset pencraft post-ufi-button style-button has-label with-border"><div class="label">Share</div></button></div></div></div></div><div><div><div class="available-content"><div dir="auto" class="body markup"><p><span>Hot off the heels of the Emergence World experiment, HarveyAI benchmarks the leading frontier models on legal tasks. </span><strong>And neither scored above 10%.</strong></p><h2 class="header-anchor-post">What Is The Harvey LAB Benchmark<div class="pencraft pc-display-flex pc-alignItems-center pc-position-absolute pc-reset header-anchor-parent"><div class="pencraft pc-display-contents pc-reset pubTheme-yiXxQA"><div id="§what-is-the-harvey-lab-benchmark" class="pencraft pc-reset header-anchor offset-top"></div><button tabindex="0" type="button" aria-label="Link" data-href="https://aigovernancelead.substack.com/i/200151013/what-is-the-harvey-lab-benchmark" class="pencraft pc-reset pencraft iconButton-mq_Et5 iconButtonBase-dJGHgN buttonBase-GK1x3M buttonStyle-r7yGCK size_sm-G3LciD priority_secondary-S63h9o"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg></button></div></div></h2><p>After watching lawyers and even judges get sanctioned for submitting AI-generated briefs full of fake cases, Harvey finally said ‘enough’ and built the benchmark the industry didn’t know it needed. </p><p><span>It’s an open source, auditable evaluation framework(called LAB) that measures how reliably large language models perform </span><em>real, long‑horizon legal work</em><span> rather than the average prompt / response requests.  </span></p><p><span>The goal is to measure </span><strong>how well frontier models do</strong><span> when performing legal reasoning, synthesis, and judgment oriented tasks. </span></p><div data-callout="true" class="callout-block"><p>Legal work carries a high bar for quality and tolerates very little error. By using realistic, messy inputs and demanding complete correctness, LAB aligns evaluation with the realistic stakes of legal work: liability, client confidentiality, and reputational risk.</p></div><h3 class="header-anchor-post">Benchmark Components : What LAB Tests<div class="pencraft pc-display-flex pc-alignItems-center pc-position-absolute pc-reset header-anchor-parent"><div class="pencraft pc-display-contents pc-reset pubTheme-yiXxQA"><div id="§benchmark-components-what-lab-tests" class="pencraft pc-reset header-anchor offset-top"></div><button tabindex="0" type="button" aria-label="Link" data-href="https://aigovernancelead.substack.com/i/200151013/benchmark-components-what-lab-tests" class="pencraft pc-reset pencraft iconButton-mq_Et5 iconButtonBase-dJGHgN buttonBase-GK1x3M buttonStyle-r7yGCK size_sm-G3LciD priority_secondary-S63h9o"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg></button></div></div></h3><ul><li><p><strong>Realistic Task Set</strong><span>. Partner‑level assignments (M&amp;A data‑room review, regulatory synthesis across jurisdictions, litigation drafting and strategy, contract redlines, corporate transaction workflows). Each task includes an instruction, a client matter (documents), and a required deliverable.</span></p></li><li><p><strong>Execution harness</strong><span>. Reproducible tooling that runs agents against tasks, supports adapters for different model providers, and enables both sequential agent simulations and large parallel sweeps.</span></p></li><li><p><strong>Granular rubrics.</strong><span> Expert‑written, itemized checks for each task (the benchmark uses thousands of rubric checks). A task is evaluated against those checks.</span></p></li><li><p><strong>All‑pass scoring rule</strong><span>. A task only “passes” if </span><strong>every</strong><span> rubric criterion is satisfied. This binary, end‑to‑end standard mirrors legal practice where partial correctness can still be harmful.</span></p></li><li><p><strong>Open‑source repo and artifacts</strong><span>. Tasks, rubrics, and harness code are published so third parties can reproduce runs and audit results.</span></p></li></ul><h3 class="header-anchor-post">Scoring Methodology<div class="pencraft pc-display-flex pc-alignItems-center pc-position-absolute pc-reset header-anchor-parent"><div class="pencraft pc-display-contents pc-reset pubTheme-yiXxQA"><div id="§scoring-methodology" class="pencraft pc-reset header-anchor offset-top"></div><button tabindex="0" type="button" aria-label="Link" data-href="https://aigovernancelead.substack.com/i/200151013/scoring-methodology" class="pencraft pc-reset pencraft iconButton-mq_Et5 iconButtonBase-dJGHgN buttonBase-GK1x3M buttonStyle-r7yGCK size_sm-G3LciD priority_secondary-S63h9o"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg></button></div></div></h3><p><span>Harvey LAB uses an </span><strong>all‑pass rubric</strong><span>: every task is evaluated against expert‑written criteria, and a task only “passes” if </span><strong>every</strong><span> criterion is satisfied. This is the eye opening insight - and it also explains why the models performed so poorly.</span></p><p><span>This binary, audit‑style scoring reflects all the rigor of legal practice where partial correctness can still be counted as malpractice. The rubric is granular (thousands of checks across the task set) to ensure pass rates reflect end‑to‑end competence over partial wins. </span><strong><a href="https://github.com/harveyai/harvey-labs">Access the full harness on Github.</a></strong></p><h2 class="header-anchor-post">What Triggered The Test<div class="pencraft pc-display-flex pc-alignItems-center pc-position-absolute pc-reset header-anchor-parent"><div class="pencraft pc-display-contents pc-reset pubTheme-yiXxQA"><div id="§what-triggered-the-test" class="pencraft pc-reset header-anchor offset-top"></div><button tabindex="0" type="button" aria-label="Link" data-href="https://aigovernancelead.substack.com/i/200151013/what-triggered-the-test" class="pencraft pc-reset pencraft iconButton-mq_Et5 iconButtonBase-dJGHgN buttonBase-GK1x3M buttonStyle-r7yGCK size_sm-G3LciD priority_secondary-S63h9o"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg></button></div></div></h2><p>Three converging forces made an auditable, domain‑specific benchmark both necessary and strategically urgent.</p><p><strong>1. Courtroom hallucinations made the risk visible.</strong><span>  </span><br/><span>High‑profile incidents where lawyers filed briefs citing non‑existent cases generated by generative models crystallized the legal danger of unverified outputs. Those episodes produced sanctions, headlines, and a sudden, practical demand from firms: if AI is used in client work, show the evidence it’s safe.</span></p><p><strong>2. A need to map capabilities to real tasks and roles.</strong><span>  </span><br/><span>Firms and risk officers require industry-wide benchmarks. They needed to know, at the task level, where frontier models actually perform, and where they fail. LAB’s partner‑style assignments (M&amp;A data rooms, regulatory synthesis, litigation drafting) were designed to reveal </span><em>which</em><span> legal activities models can assist with reliably and </span><em>which</em><span> still require human judgment.</span></p><p><strong>3. Regulatory and procurement pressure for auditable proof.</strong><span>  </span><br/><span>As regulators, bar associations, and corporate procurement teams push for documented validation of high‑risk AI, buyers now demand reproducible testing and logs. A public benchmark that publishes rubrics, harnesses, and run artifacts answers that demand and becomes a usable artifact in RFPs, compliance reviews, and regulatory submissions.</span></p><h3 class="header-anchor-post">The Outcomes: <div class="pencraft pc-display-flex pc-alignItems-center pc-position-absolute pc-reset header-anchor-parent"><div class="pencraft pc-display-contents pc-reset pubTheme-yiXxQA"><div id="§the-outcomes" class="pencraft pc-reset header-anchor offset-top"></div><button tabindex="0" type="button" aria-label="Link" data-href="https://aigovernancelead.substack.com/i/200151013/the-outcomes" class="pencraft pc-reset pencraft iconButton-mq_Et5 iconButtonBase-dJGHgN buttonBase-GK1x3M buttonStyle-r7yGCK size_sm-G3LciD priority_secondary-S63h9o"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg></button></div></div></h3><p><span>Harvey LAB benchmarked frontier models (ChatGPT, Claude Opus+, Gemini Flash 3.5) on a hold‑out evaluation set and reported three core metrics: </span><strong>end‑to‑end pass rate</strong><span>, </span><strong>latency</strong><span>, and </span><strong>cost per task</strong><span>. Headline results showed top models passing well under 10 percent of tasks under the strict standard, with the best models also being the slowest and most expensive. </span><strong><a href="https://www.harvey.ai/blog/legal-agent-benchmark-initial-results">Read more on Harvey’s blog.</a></strong></p><div class="captioned-image-container"><figure><a target="_blank" href="https://substackcdn.com/image/fetch/$s_!r9ia!,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png" data-component-name="Image2ToDOM" class="image-link image2 is-viewable-img can-restack"><div class="image2-inset"><picture><source type="image/webp" srcset="https://substackcdn.com/image/fetch/$s_!r9ia!,w_424,c_limit,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 424w, https://substackcdn.com/image/fetch/$s_!r9ia!,w_848,c_limit,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 848w, https://substackcdn.com/image/fetch/$s_!r9ia!,w_1272,c_limit,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 1272w, https://substackcdn.com/image/fetch/$s_!r9ia!,w_1456,c_limit,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 1456w" sizes="100vw"/><img src="https://substackcdn.com/image/fetch/$s_!r9ia!,w_1456,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png" width="1456" height="722" data-attrs="{&quot;src&quot;:&quot;https://substack-post-media.s3.amazonaws.com/public/images/cfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png&quot;,&quot;srcNoWatermark&quot;:null,&quot;fullscreen&quot;:null,&quot;imageSize&quot;:null,&quot;height&quot;:722,&quot;width&quot;:1456,&quot;resizeWidth&quot;:null,&quot;bytes&quot;:142265,&quot;alt&quot;:null,&quot;title&quot;:null,&quot;type&quot;:&quot;image/png&quot;,&quot;href&quot;:null,&quot;belowTheFold&quot;:true,&quot;topImage&quot;:false,&quot;internalRedirect&quot;:&quot;https://aigovernancelead.substack.com/i/200151013?img=https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png&quot;,&quot;isProcessing&quot;:false,&quot;align&quot;:null,&quot;offset&quot;:false}" alt srcset="https://substackcdn.com/image/fetch/$s_!r9ia!,w_424,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 424w, https://substackcdn.com/image/fetch/$s_!r9ia!,w_848,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 848w, https://substackcdn.com/image/fetch/$s_!r9ia!,w_1272,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 1272w, https://substackcdn.com/image/fetch/$s_!r9ia!,w_1456,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 1456w" sizes="100vw" loading="lazy" class="sizing-normal"/></picture><div class="image-link-expand"><div class="pencraft pc-display-flex pc-gap-8 pc-reset"><button tabindex="0" type="button" class="pencraft pc-reset pencraft icon-container restack-image"><svg role="img" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke-width="1.5" stroke="var(--color-fg-primary)" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><g><title></title><path d="M2.53001 7.81595C3.49179 4.73911 6.43281 2.5 9.91173 2.5C13.1684 2.5 15.9537 4.46214 17.0852 7.23684L17.6179 8.67647M17.6179 8.67647L18.5002 4.26471M17.6179 8.67647L13.6473 6.91176M17.4995 12.1841C16.5378 15.2609 13.5967 17.5 10.1178 17.5C6.86118 17.5 4.07589 15.5379 2.94432 12.7632L2.41165 11.3235M2.41165 11.3235L1.5293 15.7353M2.41165 11.3235L6.38224 13.0882"></path></g></svg></button><button tabindex="0" type="button" class="pencraft pc-reset pencraft icon-container view-image"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-maximize2 lucide-maximize-2"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" x2="14" y1="3" y2="10"></line><line x1="3" x2="10" y1="21" y2="14"></line></svg></button></div></div></div></a></figure></div><h2 class="header-anchor-post">Why Each Model Struggled: “Jagged Intelligence”<div class="pencraft pc-display-flex pc-alignItems-center pc-position-absolute pc-reset header-anchor-parent"><div class="pencraft pc-display-contents pc-reset pubTheme-yiXxQA"><div id="§why-each-model-struggled-jagged-intelligence" class="pencraft pc-reset header-anchor offset-top"></div><button tabindex="0" type="button" aria-label="Link" data-href="https://aigovernancelead.substack.com/i/200151013/why-each-model-struggled-jagged-intelligence" class="pencraft pc-reset pencraft iconButton-mq_Et5 iconButtonBase-dJGHgN buttonBase-GK1x3M buttonStyle-r7yGCK size_sm-G3LciD priority_secondary-S63h9o"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg></button></div></div></h2><p><span>LAB results found that model capability is </span><strong>unevenly distributed</strong><span> across legal domains:</span></p><ul><li><p><strong>ChatGPT‑5.5</strong><span> excels in </span><strong>regulated industries</strong><span> and </span><strong>emerging‑company work</strong><span> requiring heavy research.</span></p></li><li><p><strong>Claude Opus 4.7</strong><span> excels in </span><strong>corporate transactions</strong><span>, where synthesis and structured reasoning matter.</span></p></li><li><p><strong>No model leads in every practice area</strong><span>, the leaderboard shifts dramatically depending on the domain.</span></p></li></ul><p><span>👉 This “jagged intelligence” result is the part that will actually change how firms buy and deploy AI. Each model has different strengths. Choose the ones that will drive the highest efficiencies. </span><strong><a href="https://blockchain.news/news/harvey-legal-agent-benchmark-results">Read more on Blockchain news.</a></strong></p><h2 class="header-anchor-post">Cost &amp; Latency: The Hidden Problem<div class="pencraft pc-display-flex pc-alignItems-center pc-position-absolute pc-reset header-anchor-parent"><div class="pencraft pc-display-contents pc-reset pubTheme-yiXxQA"><div id="§cost-and-latency-the-hidden-problem" class="pencraft pc-reset header-anchor offset-top"></div><button tabindex="0" type="button" aria-label="Link" data-href="https://aigovernancelead.substack.com/i/200151013/cost-and-latency-the-hidden-problem" class="pencraft pc-reset pencraft iconButton-mq_Et5 iconButtonBase-dJGHgN buttonBase-GK1x3M buttonStyle-r7yGCK size_sm-G3LciD priority_secondary-S63h9o"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg></button></div></div></h2><p><span>LAB results  emphasize that the best models are </span><strong>expensive and slow</strong><span>:</span></p><ul><li><p><strong>Claude Opus 4.7</strong><span> costs </span><strong>~$50.90 per task</strong><span> and takes </span><strong>~22 minutes</strong><span> to complete a single LAB task.</span></p></li><li><p><span>By comparison</span><strong>, Gemini 3.5 Flash</strong><span> is much faster (under 6 minutes) but nearly useless for high‑precision legal work.</span></p></li></ul><p><span>👉 This creates a real operational trade‑off for law firms in terms of </span><strong>speed vs. accuracy vs. cost</strong><span>.</span></p><h2 class="header-anchor-post">Behavioral Insights: What Successful Agents Do<div class="pencraft pc-display-flex pc-alignItems-center pc-position-absolute pc-reset header-anchor-parent"><div class="pencraft pc-display-contents pc-reset pubTheme-yiXxQA"><div id="§behavioral-insights-what-successful-agents-do" class="pencraft pc-reset header-anchor offset-top"></div><button tabindex="0" type="button" aria-label="Link" data-href="https://aigovernancelead.substack.com/i/200151013/behavioral-insights-what-successful-agents-do" class="pencraft pc-reset pencraft iconButton-mq_Et5 iconButtonBase-dJGHgN buttonBase-GK1x3M buttonStyle-r7yGCK size_sm-G3LciD priority_secondary-S63h9o"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg></button></div></div></h2><p><span>It was an added benefit that Harvey’s LAB also analyzed </span><em>how</em><span> agents behave, not just their performance scores. High‑performing agents tend to:</span></p><ul><li><p><span>Conduct </span><strong>thorough research before drafting</strong></p></li><li><p><span>Perform </span><strong>post‑draft validation</strong></p></li><li><p><span>Use </span><strong>iterative revision loops</strong></p></li><li><p><span>Mirror the workflow of a </span><strong>skilled human associate</strong></p></li></ul><p><span>👉 This suggests that </span><strong>agent architecture</strong><span> and </span><strong>workflow design</strong><span> matter as much as the underlying model.</span></p><h2 class="header-anchor-post">Conclusion<div class="pencraft pc-display-flex pc-alignItems-center pc-position-absolute pc-reset header-anchor-parent"><div class="pencraft pc-display-contents pc-reset pubTheme-yiXxQA"><div id="§conclusion" class="pencraft pc-reset header-anchor offset-top"></div><button tabindex="0" type="button" aria-label="Link" data-href="https://aigovernancelead.substack.com/i/200151013/conclusion" class="pencraft pc-reset pencraft iconButton-mq_Et5 iconButtonBase-dJGHgN buttonBase-GK1x3M buttonStyle-r7yGCK size_sm-G3LciD priority_secondary-S63h9o"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg></button></div></div></h2><p>Here’s my bottom line. Harvey’s LAB is the most serious, auditable attempt I’ve seen to measure whether these models are actually ready for real legal work. And, we have to admit that the results, as they are today, are humbling. </p><p>Although AI isn’t replacing lawyers anytime soon, smart firms who leverage its strengths as a powerful, flawed junior associate (with strict supervision) will win.</p><p><strong>Credit where it’s due:</strong><span> We have to acknowledge what HarveyAI has accomplished. By filling this void in the industry, they’ve taken the first steps of becoming an arbiter of sorts - determining what models can meet the needs of legal professionals across the board by handing them trusted:</span></p><ul><li><p>empirical benchmarks</p></li><li><p>domain‑specific evaluation</p></li><li><p>expert‑written rubrics</p></li><li><p>reproducible scoring</p></li></ul><div data-callout="true" class="callout-block"><p><strong>The real question now is: what should firms actually DO with these results? </strong></p><p><strong>I break it down below with:</strong></p><ul><li><p><em>3 Practical Guidelines for AI Governance Teams</em></p></li><li><p><em>4 Executive Takeaways</em></p></li><li><p><em>5 Pitfalls to Avoid</em></p></li></ul><p><strong>👇Upgrade below to unlock the practical playbook.</strong></p></div></div></div></div><div data-testid="paywall" data-component-name="Paywall" role="region" aria-label="Paywall" class="paywall"><h2 class="paywall-title">This post is for paid subscribers</h2><div class="paywall-cta"><a href="https://aigovernancelead.substack.com/subscribe?simple=true&amp;next=https%3A%2F%2Faigovernancelead.substack.com%2Fp%2Fharvey-lab-legal-ai-benchmark-responsible-ai&amp;utm_source=paywall&amp;utm_medium=web&amp;utm_content=200151013" data-native="true"><button tabindex="0" type="button" class="pencraft pc-reset pencraft subscribe-btn subscribeButton-LcKYi7 buttonBase-GK1x3M">Subscribe</button></a></div><div class="paywall-login"><a href="https://substack.com/sign-in?redirect=%2Fp%2Fharvey-lab-legal-ai-benchmark-responsible-ai&amp;for_pub=aigovernancelead&amp;change_user=false" data-native="true">Already a paid subscriber? <b>Sign in</b></a></div></div><div class="pencraft pc-display-contents pc-reset pubTheme-yiXxQA"><div class="pencraft pc-display-flex pc-paddingTop-16 pc-paddingBottom-16 pc-justifyContent-space-between pc-reset"><button tabindex="0" type="button" class="pencraft pc-reset pencraft buttonBase-GK1x3M buttonText-X0uSmG buttonStyle-r7yGCK priority_secondary-S63h9o size_md-gCDS3o"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>Previous</button><button tabindex="0" type="button" class="pencraft pc-reset pencraft buttonBase-GK1x3M buttonText-X0uSmG buttonStyle-r7yGCK priority_secondary-S63h9o size_md-gCDS3o">Next<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg></button></div></div></div></article></div></div></div><div class="pencraft pc-display-contents pc-reset pubTheme-yiXxQA"></div></div></div><div class="pencraft pc-display-flex pc-flexDirection-column pc-reset container-K5XPov"></div><div class="pencraft pc-display-contents pc-reset pubTheme-yiXxQA"><div class="footer-wrap compact-footer"><div class="visibility-check"></div><div class="footer custom-themed-background"><div class="pencraft pc-display-flex pc-gap-12 pc-alignItems-center pc-reset flex-grow-rzmknG"><div class="pencraft pc-display-flex pc-minWidth-0 pc-reset flex-grow-rzmknG nowrap-QngyoB"><span><span>© 2026 LXLTH MEDIA</span><span> · </span><a href="https://substack.com/privacy" target="_blank" rel="noopener" class="pencraft pc-reset decoration-underline-ClTkYc">Privacy</a><span> ∙ </span><a href="https://substack.com/tos" target="_blank" rel="noopener" class="pencraft pc-reset decoration-underline-ClTkYc">Terms</a><span> ∙ </span><a href="https://substack.com/ccpa#personal-data-collected" target="_blank" rel="noopener" class="pencraft pc-reset decoration-underline-ClTkYc">Collection notice</a></span></div><div class="pencraft pc-display-flex pc-reset"><div class="pencraft pc-display-flex pc-gap-8 pc-justifyContent-center pc-alignItems-center pc-reset footerButtons-ap9Sk7"><a data-native="true" href="https://substack.com/signup?utm_source=substack&amp;utm_medium=web&amp;utm_content=footer" class="footerSubstackCta-v5HWfj sizeSm-F_aC8H"><svg role="img" width="1000" height="1000