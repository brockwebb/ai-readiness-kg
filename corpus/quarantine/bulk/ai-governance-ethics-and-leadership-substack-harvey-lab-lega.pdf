abled\":false,\"android_polymarket_embed_search\":false,\"automod_admin_hidden_comments_tab\":false,\"enable_subscribers_comment_permission\":false,\"translate_posts_on_standalone_sites\":false,\"search_ranker_variant\":\"control\",\"enable_dynamic_content\":false,\"permalink_reply_ranking_variant\":\"experiment\",\"allow_feed_category_filtering\":false,\"private_live_streaming_enabled\":true,\"desktop_live_stream_safe_framing\":0.8},\"trackingTokens\":{\"fbPixelId\":null,\"gaPixelId\":null,\"twitterPixelId\":null,\"parselyPixelId\":null,\"googleTagManagerToken\":null,\"googleAnalytics4Token\":null,\"twitterPixelSignupEventId\":null,\"twitterPixelSubscribeEventId\":null},\"publicationSettings\":{\"block_ai_crawlers\":false,\"credit_token_enabled\":true,\"custom_tos_and_privacy\":false,\"did_identity\":null,\"disable_optimistic_bank_payments\":false,\"display_welcome_page_details\":false,\"payment_pledges_enabled\":false,\"enable_drop_caps\":false,\"enable_post_page_conversion\":true,\"enable_prev_next_nav\":true,\"enable_restacking\":true,\"founding_group_subscriptions_enabled\":false,\"gifts_from_substack_disabled\":false,\"google_analytics_4_token\":null,\"group_sections_and_podcasts_in_menu_enabled\":false,\"live_stream_homepage_visibility\":\"contributorsAndAdmins\",\"live_stream_homepage_style\":\"autoPlay\",\"live_stream_replay_enabled\":true,\"medium_length_description\":\"AI Governance, Ethics and Leadership is a weekly publication that examines how artificial intelligence is built, who shapes it, and what those choices mean for the rest of us. I write with precision and perspective across the full AI pipeline (from data centers and frontier models to workforce shifts and global regulation) always tracing the human impact behind the technical decisions. If you\u2019re ready to think critically and feel the signal beneath the surface, you\u2019re in the right place.\",\"notes_feed_enabled\":true,\"paywall_unlock_tokens\":false,\"post_preview_crop_gravity\":\"auto\",\"post_preview_radius\":\"xs\",\"reader_referrals_enabled\":true,\"reader_referrals_leaderboard_enabled\":true,\"seen_coming_soon_explainer\":false,\"seen_google_analytics_migration_modal\":false,\"local_currency_modal_seen\":true,\"local_payment_methods_modal_seen\":false,\"twitter_pixel_signup_event_id\":null,\"twitter_pixel_subscribe_event_id\":null,\"use_local_currency\":true,\"welcome_page_opt_out_text\":\"I prefer my AI Ungoverned\",\"cookie_settings\":\"\",\"show_restacks_below_posts\":true,\"holiday_gifting_post_header\":true,\"homepage_message_text\":\"\",\"homepage_message_link\":\"\",\"about_us_author_ids\":\"\",\"archived_section_ids\":\"\",\"column_section_ids\":\"\",\"fp_primary_column_section_ids\":\"\",\"event_section_ids\":\"\",\"podcasts_metadata\":\"\",\"video_section_ids\":\"\",\"post_metering_enabled\":false,\"account_based_post_metering_enabled\":false,\"use_custom_theme\":false,\"reply_rules\":null,\"automatic_moderation_enabled\":true,\"auto_translate_enabled\":true,\"additional_post_languages_enabled\":false,\"high_res_recording_beta\":false},\"publicationUserSettings\":null,\"userSettings\":{\"user_id\":null,\"activity_likes_enabled\":true,\"dashboard_nav_refresh_enabled\":false,\"is_guest_post_enabled\":true,\"invite_friends_nux_dismissed_at\":null,\"suggestions_feed_item_last_shown_at\":null,\"last_notification_alert_shown_at\":null,\"disable_reply_hiding\":false,\"newest_seen_chat_item_published_at\":null,\"explicitContentEnabled\":false,\"contactMatchingEnabled\":false,\"messageRequestLevel\":\"everyone\",\"liveStreamAcceptableInviteLevel\":\"everyone\",\"liveStreamAcceptableChatLevel\":\"everyone\",\"creditTokensTreatmentExposed\":false,\"appBadgeIncludesChat\":false,\"autoPlayVideo\":true,\"autoAdvanceVideo\":true,\"smart_delivery_enabled\":false,\"chatbotTermsLastAcceptedAt\":null,\"has_seen_notes_post_app_upsell\":false,\"first_note_id\":null,\"show_concurrent_live_stream_viewers\":false,\"edit_profile_feed_item_dismissed_at\":null,\"mobile_permalink_app_upsell_seen_at\":null,\"new_user_checklist_enabled\":false,\"has_seen_youtube_shorts_auto_publish_announcement\":false,\"has_seen_publish_youtube_connect_upsell\":false,\"notificationQualityFilterEnabled\":true,\"hasSeenOnboardingNewslettersScreen\":false,\"bestsellerBadgeEnabled\":true,\"hasSelfIdentifiedAsCreator\":false,\"autoTranslateEnabled\":true,\"autoTranslateBlocklist\":[],\"fineTuneFeedItemSeenAt\":null,\"fineTuneFeedItemDismissedAt\":null,\"aiGeneratedTextMode\":\"show\"},\"subscriberCountDetails\":\"thousands of subscribers\",\"mux_env_key\":\"u42pci814i6011qg3segrcpp9\",\"persona_environment_id\":\"env_o1Lbk4JhpY4PmvNkwaBdYwe5Fzkt\",\"sentry_environment\":\"production\",\"launchWelcomePage\":false,\"pendingInviteForActiveLiveStream\":null,\"isEligibleForLiveStreamCreation\":true,\"webviewPlatform\":null,\"noIndex\":false,\"post\":{\"audience\":\"only_paid\",\"audience_before_archived\":null,\"canonical_url\":\"https://aigovernancelead.substack.com/p/harvey-lab-legal-ai-benchmark-responsible-ai\",\"default_comment_sort\":null,\"editor_v2\":false,\"exempt_from_archive_paywall\":false,\"free_unlock_required\":false,\"id\":200151013,\"podcast_art_url\":null,\"podcast_duration\":null,\"podcast_preview_upload_id\":null,\"podcast_upload_id\":null,\"podcast_url\":null,\"post_date\":\"2026-06-01T21:08:39.323Z\",\"updated_at\":\"2026-06-01T21:09:40.240Z\",\"publication_id\":4560681,\"search_engine_description\":null,\"search_engine_title\":null,\"section_id\":null,\"should_send_free_preview\":true,\"show_guest_bios\":true,\"slug\":\"harvey-lab-legal-ai-benchmark-responsible-ai\",\"social_title\":\"AI Governance In Action: Harvey LAB Benchmark Puts Claude, Gemini, and ChatGPT to the Test\",\"subtitle\":\"A brutal, auditable stress test that turns model claims into governance evidence for firms, courts, and regulators.\",\"teaser_post_eligible\":true,\"title\":\"AI Governance In Action: Harvey LAB Benchmark Puts Claude, Gemini, and ChatGPT to the Test\",\"type\":\"newsletter\",\"video_upload_id\":null,\"write_comment_permissions\":\"only_paid\",\"meter_type\":\"none\",\"live_stream_id\":null,\"is_published\":true,\"restacks\":8,\"reactions\":{\"\u2764\":58},\"top_exclusions\":[],\"pins\":[],\"section_pins\":[],\"has_shareable_clips\":false,\"previous_post_slug\":\"pope-first-encyclical-ai-2026-anthropic-hard-questions-responsible-ai\",\"next_post_slug\":\"ai-pilots-low-roi-roundup-responsible-ai-ca-bans-ai-companion-toysl\",\"cover_image\":\"https://substack-post-media.s3.amazonaws.com/public/images/af745517-2009-4274-bb67-aa080d46140e_1920x1080.png\",\"cover_image_is_square\":false,\"cover_image_is_explicit\":false,\"videoUpload\":null,\"podcastFields\":{\"post_id\":200151013,\"podcast_episode_number\":null,\"podcast_season_number\":null,\"podcast_episode_type\":null,\"should_syndicate_to_other_feed\":null,\"syndicate_to_section_id\":null,\"hide_from_feed\":false,\"free_podcast_url\":null,\"free_podcast_duration\":null,\"preview_contains_ad\":false,\"was_imported_self_serve_sync\":false,\"draft_free_podcast_url\":null,\"draft_free_podcast_duration\":null},\"podcastUpload\":null,\"podcastPreviewUpload\":null,\"voiceover_upload_id\":null,\"voiceoverUpload\":null,\"has_voiceover\":false,\"description\":\"HarveyAI just dropped LAB \u2014 a tough new open-source benchmark testing frontier models (GPT, Claude, Gemini) on real partner-level legal work. The results are humbling: top models pass under 10% of tasks. Discover jagged intelligence, cost/latency trade-offs, and practical guidance for law firms adopting AI safely. All from AI Governance, Ethics & Leadership. The premier destination for AI Governance & Responsible AI.\",\"body_html\":\"<p>Hot off the heels of the Emergence World experiment, HarveyAI benchmarks the leading frontier models on legal tasks. <strong>And neither scored above 10%.</strong></p><h2>What Is The Harvey LAB Benchmark</h2><p>After watching lawyers and even judges get sanctioned for submitting AI-generated briefs full of fake cases, Harvey finally said \u2018enough\u2019 and built the benchmark the industry didn\u2019t know it needed. </p><p>It\u2019s an open source, auditable evaluation framework(called LAB) that measures how reliably large language models perform <em>real, long\u2011horizon legal work</em> rather than the average prompt / response requests.  </p><p>The goal is to measure <strong>how well frontier models do</strong> when performing legal reasoning, synthesis, and judgment oriented tasks. </p><div class=\\\"callout-block\\\" data-callout=\\\"true\\\"><p>Legal work carries a high bar for quality and tolerates very little error. By using realistic, messy inputs and demanding complete correctness, LAB aligns evaluation with the realistic stakes of legal work: liability, client confidentiality, and reputational risk.</p></div><h3>Benchmark Components : What LAB Tests</h3><ul><li><p><strong>Realistic Task Set</strong>. Partner\u2011level assignments (M&amp;A data\u2011room review, regulatory synthesis across jurisdictions, litigation drafting and strategy, contract redlines, corporate transaction workflows). Each task includes an instruction, a client matter (documents), and a required deliverable.</p></li><li><p><strong>Execution harness</strong>. Reproducible tooling that runs agents against tasks, supports adapters for different model providers, and enables both sequential agent simulations and large parallel sweeps.</p></li><li><p><strong>Granular rubrics.</strong> Expert\u2011written, itemized checks for each task (the benchmark uses thousands of rubric checks). A task is evaluated against those checks.</p></li><li><p><strong>All\u2011pass scoring rule</strong>. A task only \u201Cpasses\u201D if <strong>every</strong> rubric criterion is satisfied. This binary, end\u2011to\u2011end standard mirrors legal practice where partial correctness can still be harmful.</p></li><li><p><strong>Open\u2011source repo and artifacts</strong>. Tasks, rubrics, and harness code are published so third parties can reproduce runs and audit results.</p></li></ul><h3>Scoring Methodology</h3><p>Harvey LAB uses an <strong>all\u2011pass rubric</strong>: every task is evaluated against expert\u2011written criteria, and a task only \u201Cpasses\u201D if <strong>every</strong> criterion is satisfied. This is the eye opening insight - and it also explains why the models performed so poorly.</p><p>This binary, audit\u2011style scoring reflects all the rigor of legal practice where partial correctness can still be counted as malpractice. The rubric is granular (thousands of checks across the task set) to ensure pass rates reflect end\u2011to\u2011end competence over partial wins. <strong><a href=\\\"https://github.com/harveyai/harvey-labs\\\">Access the full harness on Github.</a></strong></p><h2>What Triggered The Test</h2><p>Three converging forces made an auditable, domain\u2011specific benchmark both necessary and strategically urgent.</p><p><strong>1. Courtroom hallucinations made the risk visible.</strong>  <br>High\u2011profile incidents where lawyers filed briefs citing non\u2011existent cases generated by generative models crystallized the legal danger of unverified outputs. Those episodes produced sanctions, headlines, and a sudden, practical demand from firms: if AI is used in client work, show the evidence it\u2019s safe.</p><p><strong>2. A need to map capabilities to real tasks and roles.</strong>  <br>Firms and risk officers require industry-wide benchmarks. They needed to know, at the task level, where frontier models actually perform, and where they fail. LAB\u2019s partner\u2011style assignments (M&amp;A data rooms, regulatory synthesis, litigation drafting) were designed to reveal <em>which</em> legal activities models can assist with reliably and <em>which</em> still require human judgment.</p><p><strong>3. Regulatory and procurement pressure for auditable proof.</strong>  <br>As regulators, bar associations, and corporate procurement teams push for documented validation of high\u2011risk AI, buyers now demand reproducible testing and logs. A public benchmark that publishes rubrics, harnesses, and run artifacts answers that demand and becomes a usable artifact in RFPs, compliance reviews, and regulatory submissions.</p><h3>The Outcomes: </h3><p>Harvey LAB benchmarked frontier models (ChatGPT, Claude Opus+, Gemini Flash 3.5) on a hold\u2011out evaluation set and reported three core metrics: <strong>end\u2011to\u2011end pass rate</strong>, <strong>latency</strong>, and <strong>cost per task</strong>. Headline results showed top models passing well under 10 percent of tasks under the strict standard, with the best models also being the slowest and most expensive. <strong><a href=\\\"https://www.harvey.ai/blog/legal-agent-benchmark-initial-results\\\">Read more on Harvey\u2019s blog.</a></strong></p><div class=\\\"captioned-image-container\\\"><figure><a class=\\\"image-link image2 is-viewable-img\\\" target=\\\"_blank\\\" href=\\\"https://substackcdn.com/image/fetch/$s_!r9ia!,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png\\\" data-component-name=\\\"Image2ToDOM\\\"><div class=\\\"image2-inset\\\"><picture><source type=\\\"image/webp\\\" srcset=\\\"https://substackcdn.com/image/fetch/$s_!r9ia!,w_424,c_limit,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 424w, https://substackcdn.com/image/fetch/$s_!r9ia!,w_848,c_limit,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 848w, https://substackcdn.com/image/fetch/$s_!r9ia!,w_1272,c_limit,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 1272w, https://substackcdn.com/image/fetch/$s_!r9ia!,w_1456,c_limit,f_webp,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 1456w\\\" sizes=\\\"100vw\\\"><img src=\\\"https://substackcdn.com/image/fetch/$s_!r9ia!,w_1456,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png\\\" width=\\\"1456\\\" height=\\\"722\\\" data-attrs=\\\"{&quot;src&quot;:&quot;https://substack-post-media.s3.amazonaws.com/public/images/cfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png&quot;,&quot;srcNoWatermark&quot;:null,&quot;fullscreen&quot;:null,&quot;imageSize&quot;:null,&quot;height&quot;:722,&quot;width&quot;:1456,&quot;resizeWidth&quot;:null,&quot;bytes&quot;:142265,&quot;alt&quot;:null,&quot;title&quot;:null,&quot;type&quot;:&quot;image/png&quot;,&quot;href&quot;:null,&quot;belowTheFold&quot;:true,&quot;topImage&quot;:false,&quot;internalRedirect&quot;:&quot;https://aigovernancelead.substack.com/i/200151013?img=https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png&quot;,&quot;isProcessing&quot;:false,&quot;align&quot;:null,&quot;offset&quot;:false}\\\" class=\\\"sizing-normal\\\" alt=\\\"\\\" srcset=\\\"https://substackcdn.com/image/fetch/$s_!r9ia!,w_424,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 424w, https://substackcdn.com/image/fetch/$s_!r9ia!,w_848,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 848w, https://substackcdn.com/image/fetch/$s_!r9ia!,w_1272,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 1272w, https://substackcdn.com/image/fetch/$s_!r9ia!,w_1456,c_limit,f_auto,q_auto:good,fl_progressive:steep/https%3A%2F%2Fsubstack-post-media.s3.amazonaws.com%2Fpublic%2Fimages%2Fcfe80392-f822-4ba0-94f4-73a0d3c4226e_1568x778.png 1456w\\\" sizes=\\\"100vw\\\" loading=\\\"lazy\\\"></picture><div class=\\\"image-link-expand\\\"><div class=\\\"pencraft pc-display-flex pc-gap-8 pc-reset\\\"><button tabindex=\\\"0\\\" type=\\\"button\\\" class=\\\"pencraft pc-reset pencraft icon-container restack-image\\\"><svg role=\\\"img\\\" width=\\\"20\\\" height=\\\"20\\\" viewBox=\\\"0 0 20 20\\\" fill=\\\"none\\\" stroke-width=\\\"1.5\\\" stroke=\\\"var(--color-fg-primary)\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\"><g><title></title><path d=\\\"M2.53001 7.81595C3.49179 4.73911 6.43281 2.5 9.91173 2.5C13.1684 2.5 15.9537 4.46214 17.0852 7.23684L17.6179 8.67647M17.6179 8.67647L18.5002 4.26471M17.6179 8.67647L13.6473 6.91176M17.4995 12.1841C16.5378 15.2609 13.5967 17.5 10.1178 17.5C6.86118 17.5 4.07589 15.5379 2.94432 12.7632L2.41165 11.3235M2.41165 11.3235L1.5293 15.7353M2.41165 11.3235L6.38224 13.0882\\\"></path></g></svg></button><button tabindex=\\\"0\\\" type=\\\"button\\\" class=\\\"pencraft pc-reset pencraft icon-container view-image\\\"><svg xmlns=\\\"http://www.w3.org/2000/svg\\\" width=\\\"20\\\" height=\\\"20\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" stroke-width=\\\"2\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" class=\\\"lucide lucide-maximize2 lucide-maximize-2\\\"><polyline points=\\\"15 3 21 3 21 9\\\"></polyline><polyline points=\\\"9 21 3 21 3 15\\\"></polyline><line x1=\\\"21\\\" x2=\\\"14\\\" y1=\\\"3\\\" y2=\\\"10\\\"></line><line x1=\\\"3\\\" x2=\\\"10\\\" y1=\\\"21\\\" y2=\\\"14\\\"></line></svg></button></div></div></div></a></figure></div><h2>Why Each Model Struggled: \u201CJagged Intelligence\u201D</h2><p>LAB results found that model capability is <strong>unevenly distributed</strong> across legal domains:</p><ul><li><p><strong>ChatGPT\u20115.5</strong> excels in <strong>regulated industries</strong> and <strong>emerging\u2011company work</strong> requiring heavy research.</p></li><li><p><strong>Claude Opus 4.7</strong> excels in <strong>corporate transactions</strong>, where synthesis and structured reasoning matter.</p></li><li><p><strong>No model leads in every practice area</strong>, the leaderboard shifts dramatically depending on the domain.</p></li></ul><p>\uD83D\uDC49 This \u201Cjagged intelligence\u201D result is the part that will actually change how firms buy and deploy AI. Each model has different strengths. Choose the ones that will drive the highest efficiencies. <strong><a href=\\\"https://blockchain.news/news/harvey-legal-agent-benchmark-results\\\">Read more on Blockchain news.</a></strong></p><h2>Cost &amp; Latency: The Hidden Problem</h2><p>LAB results  emphasize that the best models are <strong>expensive and slow</strong>:</p><ul><li><p><strong>Claude Opus 4.7</strong> costs <strong>~$50.90 per task</strong> and takes <strong>~22 minutes</strong> to complete a single LAB task.</p></li><li><p>By comparison<strong>, Gemini 3.5 Flash</strong> is much faster (under 6 minutes) but nearly useless for high\u2011precision legal work.</p></li></ul><p>\uD83D\uDC49 This creates a real operational trade\u2011off for law firms in terms of <strong>speed vs. accuracy vs. cost</strong>.</p><h2>Behavioral Insights: What Successful Agents Do</h2><p>It was an added benefit that Harvey\u2019s LAB also analyzed <em>how</em> agents behave, not just their performance scores. High\u2011performing agents tend to:</p><ul><li><p>Conduct <strong>thorough research before drafting</strong></p></li><li><p>Perform <strong>post\u2011draft validation</strong></p></li><li><p>Use <strong>iterative revision loops</strong></p></li><li><p>Mirror the workflow of a <strong>skilled human associate</strong></p></li></ul><p>\uD83D\uDC49 This suggests that <strong>agent architecture</strong> and <strong>workflow design</strong> matter as much as the underlying model.</p><h2>Conclusion</h2><p>Here\u2019s my bottom line. Harvey\u2019s LAB is the most serious, auditable attempt I\u2019ve seen to measure whether these models are actually ready for real legal work. And, we have to admit that the results, as they are today, are humbling. </p><p>Although AI isn\u2019t replacing lawyers anytime soon, smart firms who leverage its strengths as a powerful, flawed junior associate (with strict supervision) will win.</p><p><strong>Credit where it\u2019s due:</strong> We have to acknowledge what HarveyAI has accomplished. By filling this void in the industry, they\u2019ve taken the first steps of becoming an arbiter of sorts - determining what models can meet the needs of legal professionals across the board by handing them trusted:</p><ul><li><p>empirical benchmarks</p></li><li><p>domain\u2011specific evaluation</p></li><li><p>expert\u2011written rubrics</p></li><li><p>reproducible scoring</p></li></ul><div class=\\\"callout-block\\\" data-callout=\\\"true\\\"><p><strong>The real question now is: what should firms actually DO with these results? </strong></p><p><strong>I break it down below with:</strong></p><ul><li><p><em>3 Practical Guidelines for AI Governance Teams</em></p></li><li><p><em>4 Executive Takeaways</em></p></li><li><p><em>5 Pitfalls to Avoid</em></p></li></ul><p><strong>\uD83D\uDC47Upgrade below to unlock the practical playbook.</strong></p></div>\",\"has_dynamic_content\":false,\"truncated_body_text\":\"Hot off the heels of the Emergence World experiment, HarveyAI benchmarks the leading frontier models on legal tasks. And neither scored above 10%.\",\"wordcount\":1464,\"post_preview_limit\":null,\"language\":\"en\",\"postTags\":[{\"id\":\"01916899-1016-4efa-