c/images/367e26c8-29b1-418c-92ac-395f33cce4e0_589x589.png\",\"bio\":\"Stanford certified engineering leader and MBA turned AI Governance Leader. Coffee lover, plant parent and AI enthusiast.\",\"profile_set_up_at\":\"2025-03-31T14:52:42.711Z\",\"reader_installed_at\":\"2025-05-07T05:56:55.287Z\",\"publicationUsers\":[{\"id\":4652178,\"user_id\":329493704,\"publication_id\":4560681,\"role\":\"admin\",\"public\":true,\"is_primary\":true,\"publication\":{\"id\":4560681,\"name\":\"AI Governance, Ethics and Leadership\",\"subdomain\":\"aigovernancelead\",\"custom_domain\":null,\"custom_domain_optional\":false,\"hero_text\":\"I make AI governance clear, practical, and human for 7500+ people who want to lead with confidence.\",\"logo_url\":\"https://substack-post-media.s3.amazonaws.com/public/images/47869115-def2-4229-92a8-6e6aeabb12e6_896x896.png\",\"author_id\":329493704,\"primary_user_id\":329493704,\"theme_var_background_pop\":\"#FF6719\",\"created_at\":\"2025-03-31T15:12:15.306Z\",\"email_from_name\":\"AI Governance, Ethics and Leadership\",\"copyright\":\"LXLTH MEDIA\",\"founding_plan_name\":\"The Lever\",\"community_enabled\":true,\"invite_only\":false,\"payments_state\":\"enabled\",\"language\":null,\"explicit\":false,\"homepage_type\":\"magaziney\",\"is_personal_mode\":false,\"logo_url_wide\":null}}],\"is_guest\":false,\"bestseller_tier\":null,\"status\":{\"bestsellerTier\":null,\"subscriberTier\":null,\"leaderboard\":null,\"vip\":false,\"badge\":null,\"subscriber\":null}}],\"reaction\":null,\"reaction_count\":58,\"comment_count\":0,\"child_comment_count\":0,\"audio_items\":[{\"post_id\":200151013,\"voice_id\":\"en-US-AlloyTurboMultilingualNeural\",\"audio_url\":null,\"type\":\"tts\",\"status\":\"paywalled\"}],\"is_geoblocked\":false,\"hidden\":true,\"hasCashtag\":false},\"comments\":[],\"canonicalUrl\":\"https://aigovernancelead.substack.com/p/harvey-lab-legal-ai-benchmark-responsible-ai\",\"inlineComments\":false,\"readerIsSearchCrawler\":false,\"ogUrl\":\"https