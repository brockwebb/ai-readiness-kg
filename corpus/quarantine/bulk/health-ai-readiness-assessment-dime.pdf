    // 1. Find the "ALL" filter button based on its native layout class
    const allButton = document.querySelector('.fs-grid-filter-all a, [uk-filter-control=""] a, .fs-filter-grid [uk-filter-control] a:not([data-filter])');
    
    // Fallback: If Grid Pro uses a specific button class, find any active "ALL" nav target
    const fallbackAllBtn = document.querySelector('.fs-filter-grid ul li:first-child a');

    const targetButton = allButton || fallbackAllBtn;

    if (targetButton) {
        targetButton.addEventListener('click', function() {
            // 2. Clear the hash without forcing a page reload/jump
            setTimeout(function() {
                // Using history.pushState prevents the page from flickering or jumping
                history.pushState("", document.title, window.location.pathname + window.location.search);
            }, 50); // A tiny 50ms delay lets the plugin finish its sorting math first
        });
    }
