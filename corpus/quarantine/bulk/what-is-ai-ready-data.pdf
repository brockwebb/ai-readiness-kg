12.3,22.35,15.64z M19.341,15.64h2.288c-0.187-2.943-2.64-5.28-5.629-5.28c-0.91,0-1.77,0.217-2.532,0.601 l1.15,1.976c0.422-0.191,0.89-0.297,1.382-0.297C17.731,12.64,19.161,13.956,19.341,15.64z M9,3.36C8.647,3.36,8.36,3.647,8.36,4 S8.647,4.64,9,4.64S9.64,4.353,9.64,4S9.353,3.36,9,3.36z"/></svg>
