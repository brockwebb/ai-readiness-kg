                <stop stop-color="#1192E8"/>
            </linearGradient>
            <linearGradient id="pictogram-color-purple-60-939c309f-8bd0-4340-b2c4-eaf721b05a2e">
                <stop stop-color="#8A3FFC"/>
            </linearGradient>
            <linearGradient id="pictogram-color-green-50-939c309f-8bd0-4340-b2c4-eaf721b05a2e">
                <stop stop-color="#24a148"/>
            </linearGradient>
            <linearGradient id="pictogram-color-teal-50-939c309f-8bd0-4340-b2c4-eaf721b05a2e">
                <stop stop-color="#009d9a"/>
            </linearGradient>
            <linearGradient id="pictogram-color-magenta-50-939c309f-8bd0-4340-b2c4-eaf721b05a2e">
                <stop stop-color="#EE5396"/>
            </linearGradient>
            <linearGradient id="pictogram-color-red-60-939c309f-8bd0-4340-b2c4-eaf721b05a2e">
                <stop stop-color="#DA1E28"/>
            </linearGradient>
